---
import Base from '../layouts/Base.astro';
const jsonLd = [
  {"@context":"https://schema.org","@type":"Organization","name":"FaktenSchmied GmbH","url":"https://www.faktenschmied.de/","email":"Jennifer.Raidel@faktenschmied.de","telephone":"+49-981-208-6261-0","address":{"@type":"PostalAddress","streetAddress":"Bahnhofstraße 2","postalCode":"91522","addressLocality":"Ansbach","addressCountry":"DE"}}
];
---
<Base title='Demo anfragen — BrandFacts kostenlos kennenlernen | FaktenSchmied' description='Fragen Sie eine kostenlose BrandFacts-Demo an: kostenloses Teams-Meeting, Bedarf klären, Tool live erleben — unverbindlich. FaktenSchmied GmbH, Ansbach.' path="/demo" active="" jsonLd={jsonLd}>
<!-- HERO + FORM -->
<section class="hero interior" style="padding-bottom:64px">
  <div class="mesh"></div><div class="grain"></div>
  <div class="wrap">
    <div class="crumb reveal"><a href="/">Start</a><span class="sep">/</span>Demo</div>
    <div class="ey on-dark reveal">Kostenlose Demo</div>
    <h1 class="reveal" style="transition-delay:.08s">Sehen Sie BrandFacts <span class="serif-it o">an Ihren Fragen.</span></h1>
    <p class="sub reveal" style="transition-delay:.16s">Ein kostenloses Teams-Meeting: Wir klären Ihren Bedarf und zeigen das Tool live — kein Verkaufstheater, keine Verpflichtung. Antwort in der Regel innerhalb eines Werktags.</p>
  </div>
</section>

<section class="demo" id="form" style="padding-top:72px">
  <div class="wrap split">
    <div class="lead reveal">
      <div class="ey"><span class="ix">(01)</span> Ablauf</div>
      <h2 style="margin-top:18px;font-size:clamp(1.9rem,3.2vw,2.6rem)">Was Sie erwartet</h2>
      <div class="exp">
        <div class="li"><span class="b">1</span><span><b>Bedarf klären</b><span>Wir verstehen Ihren Markt, Ihre Branche und Ihre konkreten Fragen.</span></span></div>
        <div class="li"><span class="b">2</span><span><b>Tool live erleben</b><span>BrandFacts an realen Beispielen — Werbedruck, Inhalte, Spendings.</span></span></div>
        <div class="li"><span class="b">3</span><span><b>Individueller Zuschnitt</b><span>Wir ermitteln die Segmente, die für Sie relevant sind — unverbindlich.</span></span></div>
      </div>
      <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--line)">
        <div class="ey"><span class="ix">(02)</span> Direkt erreichbar</div>
        <p style="margin-top:18px;font-size:16px;line-height:1.9;color:var(--ink)">
          <b>FaktenSchmied GmbH</b><br>
          Bahnhofstraße 2 · 91522 Ansbach<br>
          <a href="tel:+499812086261">+49 (0) 981 208 6261-0</a><br>
          <a href="mailto:Jennifer.Raidel@faktenschmied.de">Jennifer.Raidel@faktenschmied.de</a>
        </p>
      </div>
    </div>
    <div class="reveal" style="transition-delay:.12s">
      <form class="form js-demo" novalidate>
        <h3>Demo anfragen</h3>
        <div class="fsub">// antwort i. d. r. innerhalb eines werktags</div>
        <div class="grid2">
          <div class="fld"><input id="vn" name="vorname" placeholder=" "><label for="vn">Vorname</label></div>
          <div class="fld"><input id="nn" name="nachname" placeholder=" "><label for="nn">Nachname <span class="req">*</span></label></div>
        </div>
        <div class="fld"><input id="em" name="email" type="email" placeholder=" "><label for="em">Geschäftliche E-Mail <span class="req">*</span></label></div>
        <div class="grid2">
          <div class="fld"><input id="fa" name="unternehmen" placeholder=" "><label for="fa">Unternehmen</label></div>
          <div class="fld"><input id="tel" name="telefon" placeholder=" "><label for="tel">Telefon</label></div>
        </div>
        <div class="fld"><select id="br" name="branche" required><option value="" selected disabled hidden></option><option>Rx / Pharma</option><option>Dental</option><option>Veterinär</option><option>Agentur</option><option>Sonstiges</option></select><label for="br">Branche</label></div>
        <div class="fld"><textarea id="ms" name="nachricht" placeholder=" "></textarea><label for="ms">Ihr Anliegen</label></div>
        <div class="consent"><input type="checkbox" id="cs"><label for="cs">Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung der Anfrage zu. <span class="req">*</span></label></div>
        <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp" />
        <div class="form-status" role="status" aria-live="polite"></div>
        <button class="btn btn-primary btn-block btn-lg" type="submit"><span class="lbl">Demo anfragen <span class="ar">→</span></span></button>
        <div class="trustline"><span>DSGVO-konform</span><span>Spam-Schutz</span><span>kein Verkaufsdruck</span></div>
      </form>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faqsec">
  <div class="wrap">
    <div class="sec-head center reveal">
      <div class="ey"><span class="ix">(03)</span> FAQ</div>
      <h2>Bevor Sie anfragen</h2>
    </div>
    <div class="faq reveal">
      <details open><summary>Ist die Demo wirklich kostenlos?<span class="pm">▾</span></summary><div class="a">Ja. Die Demo ist ein kostenloses Teams-Meeting — wir klären Ihren Bedarf und zeigen BrandFacts, ohne Verpflichtung.</div></details>
      <details><summary>Wie lange dauert sie?<span class="pm">▾</span></summary><div class="a">In der Regel rund 30 Minuten. Auf Wunsch gehen wir tiefer auf Ihre Branche und Fragestellungen ein.</div></details>
      <details><summary>Was sollte ich vorbereiten?<span class="pm">▾</span></summary><div class="a">Nichts Aufwendiges. Hilfreich sind Ihre Branche, Ihr Wettbewerbsumfeld und die Fragen, die Sie beschäftigen.</div></details>
      <details><summary>Was passiert mit meinen Daten?<span class="pm">▾</span></summary><div class="a">Ihre Angaben werden ausschließlich zur Bearbeitung der Anfrage genutzt und DSGVO-konform verarbeitet. Details in der Datenschutzerklärung.</div></details>
    </div>
  </div>
</section>

<!-- FOOTER -->
</Base>
