---
import Base from '../../layouts/Base.astro';
const jsonLd = [
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Start","item":"https://www.faktenschmied.de/"},{"@type":"ListItem","position":2,"name":"BrandFacts","item":"https://www.faktenschmied.de/brandfacts"},{"@type":"ListItem","position":3,"name":"Rx-Werbemonitoring","item":"https://www.faktenschmied.de/brandfacts/rx-werbemonitoring"}]}
];
---
<Base title='Rx-Werbemonitoring — Pharma-Werbeanalyse mit ATC-Logik | FaktenSchmied' description='Rx-Werbemonitoring mit BrandFacts: über 700 Fachzeitschriften und 540 Verlags-Newsletter, täglich erfasst, nach ATC-Code zugeordnet und nach Indikation filterbar. Pharma-Werbedruck, -inhalte und -spendings analysieren.' path="/brandfacts/rx-werbemonitoring" active="branchen" jsonLd={jsonLd}>
<!-- HERO -->
<section class="hero interior home">
  <div class="mesh"></div><div class="grain"></div>
  <div class="wrap">
    <div>
      <div class="crumb reveal"><a href="/">Start</a><span class="sep">/</span><a href="/brandfacts">BrandFacts</a><span class="sep">/</span>Rx</div>
      <div class="ey on-dark reveal">Branche · Rx / Pharma</div>
      <h1 class="reveal" style="transition-delay:.08s">Pharma-Werbung — <span class="serif-it o">ATC-genau und indikationsscharf.</span></h1>
      <p class="sub reveal" style="transition-delay:.16s">BrandFacts überwacht die Werbemaßnahmen Ihrer Wettbewerber im Rx-Markt präzise: täglich erfasst, nach ATC-Code zugeordnet und nach Indikation filterbar — über Print und Digital. So planen Sie Budgets effizienter und reagieren schneller.</p>
      <div class="acts reveal" style="transition-delay:.24s">
        <a class="btn btn-primary btn-lg" href="/demo" id="magnet"><span class="lbl">Rx-Demo anfragen <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/brandfacts"><span class="lbl">BrandFacts im Überblick</span></a>
      </div>
    </div>
    <div class="reveal" style="transition-delay:.2s">
      <div class="glass" id="tilt" aria-hidden="true">
        <div class="gh"><i></i><i></i><i></i><span class="t">rx › werbedruck · indikation</span></div>
        <div class="gb">
          <div class="gr"><span>ATC A — Indikation X</span><span>41%</span></div><div class="gbar"><span data-w="88%" style="background:var(--brand)"></span></div>
          <div class="gr"><span>ATC B — Indikation Y</span><span>29%</span></div><div class="gbar"><span data-w="64%" style="background:var(--viz-2)"></span></div>
          <div class="gr"><span>ATC C — Indikation Z</span><span>17%</span></div><div class="gbar"><span data-w="42%" style="background:var(--viz-3)"></span></div>
          <div class="gchart"><i class="c" data-h="50%"></i><i class="c" data-h="68%"></i><i class="c" data-h="62%"></i><i class="c" data-h="84%"></i><i class="c" data-h="96%"></i><i class="c" data-h="80%"></i></div>
        </div>
      </div>
      <div class="chip"><span class="v">&gt;700</span><span class="k">Fachzeitschriften<br>täglich erfasst</span></div>
    </div>
  </div>
</section>

<!-- PROOF -->
<div class="proof">
  <div class="wrap">
    <div class="it reveal"><div class="n">&gt;<span data-count="700">0</span></div><div class="l">Fachzeitschriften · DACH</div></div>
    <div class="it reveal" style="transition-delay:.08s"><div class="n">&gt;<span data-count="540">0</span></div><div class="l">pharm. Verlags-Newsletter</div></div>
    <div class="it reveal" style="transition-delay:.16s"><div class="n">täglich</div><div class="l">Erfassungsrhythmus</div></div>
    <div class="it reveal" style="transition-delay:.24s"><div class="n">ATC</div><div class="l">+ Indikationsfilter</div></div>
  </div>
</div>

<!-- WHAT -->
<section>
  <div class="wrap split top">
    <div class="reveal">
      <div class="ey"><span class="ix">(01)</span> Strategischer Vorteil</div>
      <h2 style="margin-top:18px">Den vollständigen Überblick behalten — bevor andere reagieren.</h2>
      <p class="big">Täglich werden mehr als <b>700 Fachzeitschriften</b> aus dem D-A-CH-Raum analysiert: klassische Werbeanzeigen, bezahlte PR, Advertorials und Sonderveröffentlichungen fließen in die BrandFacts-Datenbank. Hinzu kommen mehr als <b>540 pharmazeutische und medizinische Verlags-Newsletter</b>.</p>
      <p class="big">Damit erhalten Sie im Bereich Rx ein umfangreiches Monitoring über den Print- und Digital-Sektor — die Grundlage, um Werbedruck, Inhalte und Spendings Ihrer Mitbewerber belastbar zu vergleichen.</p>
      <a class="btn btn-line" style="margin-top:14px" href="/methodik"><span class="lbl">Wie wir erfassen <span class="ar">→</span></span></a>
    </div>
    <div class="reveal" style="transition-delay:.12s">
      <div class="panel">
        <div class="ph"><span class="t">rx · share of voice · zeitverlauf</span><span class="seg"><b class="on">Print</b><b>Digital</b></span></div>
        <div class="schem">
          <div class="schem-plot">
            <div class="schem-grp"><span class="sb b" style="height:44%"></span><span class="sb a" style="height:58%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:52%"></span><span class="sb a" style="height:50%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:48%"></span><span class="sb a" style="height:66%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:60%"></span><span class="sb a" style="height:76%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:54%"></span><span class="sb a" style="height:88%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:66%"></span><span class="sb a" style="height:96%"></span></div>
          </div>
          <div class="schem-foot"><span class="schem-leg"><i class="a"></i>Ihre Marke</span><span class="schem-leg"><i class="b"></i>Wettbewerb</span><span class="schem-time">Zeitverlauf →</span></div>
        </div>
        <div class="cap">// schematische Darstellung · eine Indikation</div>
      </div>
    </div>
  </div>
</section>

<!-- CONTENT TYPES -->
<section class="feat">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(02)</span> Was erfasst wird</div>
      <h2>Jede relevante Werbeform im Rx-Markt</h2>
    </div>
    <div class="bento reveal cols-2">
      <div class="cell"><div class="ix">01</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586z"/></svg></div><h4>Klassische Werbeanzeigen</h4><p>Print-Anzeigen aus über 700 Fachzeitschriften — vollständig erfasst und kategorisiert.</p></div>
      <div class="cell"><div class="ix">02</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c1.8 2.6 .6 4.6 0 5.6 .9-.4 1.8-1.6 2-2.6 1.8 1.8 3 4 3 6.4a5 5 0 0 1-10 0c0-2 1-3.8 2.4-5.2C11 7 11.7 4.6 12 3z"/></svg></div><h4>Bezahlte PR &amp; Advertorials</h4><p>Redaktionell anmutende Werbeformen sichtbar machen, die sonst unter dem Radar bleiben.</p></div>
      <div class="cell"><div class="ix">03</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M4.5 7h12a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-12a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1z"/><path d="M4.5 7.4 2 8.6l2.5 1.2z"/><path d="M16.5 7.2h2.3l-1 2.6h-1.3z"/><path d="M9 10h6l-1.2 5h-3.6z"/><path d="M6 15h9a1 1 0 0 1 1 1v1.3a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V16a1 1 0 0 1 1-1z"/></svg></div><h4>Sonderveröffentlichungen</h4><p>Specials und Sonderformate als Teil der Wettbewerbsbeobachtung.</p></div>
      <div class="cell"><div class="ix">04</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20v-7a5 5 0 0 1 10 0v7"/><path d="M5.5 20H8M16 20h2.5"/><circle cx="8.2" cy="11" r=".6"/><circle cx="8.5" cy="14.5" r=".6"/><circle cx="15.8" cy="11" r=".6"/><circle cx="15.5" cy="14.5" r=".6"/></svg></div><h4>Verlags-Newsletter</h4><p>Mehr als 540 pharmazeutische und medizinische Newsletter im digitalen Monitoring.</p></div>
    </div>
  </div>
</section>

<!-- ATC LOGIC -->
<section>
  <div class="wrap split rev top">
    <div class="reveal" style="transition-delay:.12s">
      <div class="panel">
        <div class="ph"><span class="t">brandfacts · filter nach atc &amp; indikation</span></div>
        <div class="chips">
          <span class="fchip"><b>A10</b> Diabetes</span>
          <span class="fchip"><b>C09</b> Kardiologie</span>
          <span class="fchip"><b>R03</b> Respiratorisch</span>
          <span class="fchip"><b>N02</b> Analgetika</span>
          <span class="fchip"><b>L01</b> Onkologie</span>
          <span class="fchip"><b>J07</b> Impfstoffe</span>
          <span class="fchip on">+ Ihre Indikation</span>
        </div>
        <div class="cap">// frei kombinierbar — Sie erhalten genau Ihre Datenbasis</div>
      </div>
    </div>
    <div class="reveal">
      <div class="ey"><span class="ix">(03)</span> Ihre Datenbank, Ihr Fokus</div>
      <h2 style="margin-top:18px">Nur die Rx-Märkte, die für Sie zählen.</h2>
      <p class="big">Mit BrandFacts konzentrieren Sie sich auf die Rx-Märkte und Produktsegmente, die für Ihr Unternehmen bedeutend sind. Alle analysierten Werbeanzeigen — analog und digital — werden den entsprechenden <b>ATC-Codes</b> zugeordnet.</p>
      <p class="big">Zusätzlich filtern Sie nach <b>Indikationen</b>, um noch präzisere Einblicke zu erhalten. Ihr Werbemonitoring, unser Fokus: Erfolg im Pharmamarketing.</p>
    </div>
  </div>
</section>

<!-- USE CASES -->
<section class="feat">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(04)</span> Anwendungen im Rx-Marketing</div>
      <h2>Wofür Pharma-Teams BrandFacts nutzen</h2>
    </div>
    <div class="rows reveal">
      <a class="ucrow" href="/#usecases"><div class="ix">01</div><div><h4>Wettbewerbsanalyse</h4><p>ATC-basiert sehen, wer in welcher Indikation wie stark wirbt — und mit welcher Botschaft.</p></div><div class="go">→</div></a>
      <a class="ucrow" href="/#usecases"><div class="ix">02</div><div><h4>Mediaplanung</h4><p>Budgets und Kanäle anhand realer Wettbewerbsaktivität in Fachmedien und Newslettern planen.</p></div><div class="go">→</div></a>
      <a class="ucrow" href="/#usecases"><div class="ix">03</div><div><h4>Kampagnenentwicklung</h4><p>Im Rx-Bereich sind gezielte, kreative Kampagnen ein Muss — entwickeln Sie unique Anzeigen auf Datenbasis.</p></div><div class="go">→</div></a>
    </div>
  </div>
</section>

<!-- FORGE BAND -->
  <section>
    <div class="wrap">
      <div class="forge-band reveal">
        <img src="/img/forge-rx.webp" alt="FaktenSchmied — die Schmiedin prüft einen geschmiedeten Stab und behält den Wettbewerb im Blick." width="1200" height="820" loading="lazy" />
        <div class="cap"><div class="t">„Wettbewerber im Blick."</div><div class="s">// BrandFacts macht die Werbeaktivität im Rx-Markt sichtbar — ATC-genau.</div></div>
      </div>
    </div>
  </section>

<!-- FINAL CTA -->
<div class="final"><div class="wrap"><div class="cta reveal">
  <div class="mesh"></div>
  <h2>Sehen Sie den Rx-Werbemarkt klar.</h2>
  <p>In einer kostenlosen Demo zeigen wir BrandFacts an Ihrer Indikation und Ihrem Wettbewerbsumfeld — unverbindlich.</p>
  <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Rx-Demo anfragen <span class="ar">→</span></span></a></div>
</div></div></div>

<!-- FOOTER -->
</Base>
