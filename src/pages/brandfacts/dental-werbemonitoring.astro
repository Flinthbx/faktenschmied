---
import Base from '../../layouts/Base.astro';
const jsonLd = [
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Start","item":"https://www.faktenschmied.de/"},{"@type":"ListItem","position":2,"name":"BrandFacts","item":"https://www.faktenschmied.de/brandfacts"},{"@type":"ListItem","position":3,"name":"Dental-Werbemonitoring","item":"https://www.faktenschmied.de/brandfacts/dental-werbemonitoring"}]}
];
---
<Base title='Dental-Werbemonitoring — Werbeanalyse im Dentalmarkt | FaktenSchmied' description='Dental-Werbemonitoring mit BrandFacts: 100 Dentalfachtitel und 50 Newsletter in der DACH-Region, eingeteilt in Standard-Produktkategorien. Anzeigen, PR-Texte und Werbespendings im Dentalmarkt analysieren.' path="/brandfacts/dental-werbemonitoring" active="branchen" jsonLd={jsonLd}>
<!-- HERO -->
<section class="hero interior home">
  <div class="mesh"></div><div class="grain"></div>
  <div class="wrap">
    <div>
      <div class="crumb reveal"><a href="/">Start</a><span class="sep">/</span><a href="/brandfacts">BrandFacts</a><span class="sep">/</span>Dental</div>
      <div class="ey on-dark reveal">Branche · Dental</div>
      <h1 class="reveal" style="transition-delay:.08s">Werbung, die <span class="serif-it o">auf den Zahn fühlt.</span></h1>
      <p class="sub reveal" style="transition-delay:.16s">BrandFacts behält Ihre Konkurrenz in puncto Werbeanzeigen, Botschaften und Budgets im Blick — strukturiert nach den industrieüblichen Produktkategorien des Dentalmarkts, über Print und Digital.</p>
      <div class="acts reveal" style="transition-delay:.24s">
        <a class="btn btn-primary btn-lg" href="/demo" id="magnet"><span class="lbl">Dental-Demo anfragen <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/brandfacts"><span class="lbl">BrandFacts im Überblick</span></a>
      </div>
    </div>
    <div class="reveal" style="transition-delay:.2s">
      <div class="glass" id="tilt" aria-hidden="true">
        <div class="gh"><i></i><i></i><i></i><span class="t">dental › produktkategorie · spendings</span></div>
        <div class="gb">
          <div class="gr"><span>Implantologie</span><span>36%</span></div><div class="gbar"><span data-w="80%" style="background:var(--brand)"></span></div>
          <div class="gr"><span>Prophylaxe</span><span>28%</span></div><div class="gbar"><span data-w="62%" style="background:var(--viz-2)"></span></div>
          <div class="gr"><span>Prothetik</span><span>21%</span></div><div class="gbar"><span data-w="48%" style="background:var(--viz-3)"></span></div>
          <div class="gchart"><i class="c" data-h="46%"></i><i class="c" data-h="64%"></i><i class="c" data-h="58%"></i><i class="c" data-h="82%"></i><i class="c" data-h="90%"></i><i class="c" data-h="72%"></i></div>
        </div>
      </div>
      <div class="chip"><span class="v">100</span><span class="k">Dentalfachtitel<br>+ 50 Newsletter</span></div>
    </div>
  </div>
</section>

<!-- PROOF -->
<div class="proof">
  <div class="wrap">
    <div class="it reveal"><div class="n"><span data-count="100">0</span></div><div class="l">Dentalfachtitel · DACH</div></div>
    <div class="it reveal" style="transition-delay:.08s"><div class="n"><span data-count="50">0</span></div><div class="l">Verlags-Newsletter</div></div>
    <div class="it reveal" style="transition-delay:.16s"><div class="n">Anzeigen<span class="u"> + </span>PR</div><div class="l">erfasste Werbeformen</div></div>
    <div class="it reveal" style="transition-delay:.24s"><div class="n">Kategorien</div><div class="l">+ Untergruppen</div></div>
  </div>
</div>

<!-- WHAT -->
<section>
  <div class="wrap split top">
    <div class="reveal">
      <div class="ey"><span class="ix">(01)</span> Die Datenbasis</div>
      <h2 style="margin-top:18px">Die umfassendste Basis für Ihr Dental-Werbemonitoring in der Region D-A-CH</h2>
      <p class="big">Das FaktenSchmied-Team erfasst täglich Anzeigen und PR-Texte aus <b>100 Dentalfachtiteln</b> und <b>50 Verlags-Newslettern</b>. Die Spendings in der BrandFacts-Datenbank unterliegen den Mediadaten der Verlage.</p>
      <p class="big">In einem gemeinsamen Teams-Meeting zeigen wir Ihnen die intuitive Nutzung von BrandFacts und ermitteln Ihren individuellen Bedarf.</p>
      <a class="btn btn-line" style="margin-top:14px" href="/methodik"><span class="lbl">Wie wir erfassen <span class="ar">→</span></span></a>
    </div>
    <div class="reveal" style="transition-delay:.12s">
      <div class="panel">
        <div class="ph"><span class="t">dental · wettbewerbsvergleich</span><span class="seg"><b class="on">Print</b><b>Digital</b></span></div>
        <div class="schem">
          <div class="schem-plot">
            <div class="schem-grp"><span class="sb b" style="height:42%"></span><span class="sb a" style="height:56%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:50%"></span><span class="sb a" style="height:48%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:46%"></span><span class="sb a" style="height:66%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:58%"></span><span class="sb a" style="height:74%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:52%"></span><span class="sb a" style="height:86%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:64%"></span><span class="sb a" style="height:95%"></span></div>
          </div>
          <div class="schem-foot"><span class="schem-leg"><i class="a"></i>Ihre Marke</span><span class="schem-leg"><i class="b"></i>Wettbewerb</span><span class="schem-time">Zeitverlauf →</span></div>
        </div>
        <div class="cap">// schematische Darstellung</div>
      </div>
    </div>
  </div>
</section>

<!-- STRUCTURE -->
<section class="feat">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(02)</span> Klare Struktur</div>
      <h2>Weniger Aufwand durch strukturierte Kategorien</h2>
      <p>Alle analysierten Werbeanzeigen — analog und digital — werden in die industrieüblichen Standard-Produktkategorien und Untergruppen eingeteilt. Keine überflüssigen Daten, keine vergeudete Zeit.</p>
    </div>
    <div class="bento reveal cols-2">
      <div class="cell"><div class="ix">01</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586z"/></svg></div><h4>Anzeigen</h4><p>Print-Werbung aus 100 Dentalfachtiteln, vollständig erfasst und kategorisiert.</p></div>
      <div class="cell"><div class="ix">02</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c1.8 2.6 .6 4.6 0 5.6 .9-.4 1.8-1.6 2-2.6 1.8 1.8 3 4 3 6.4a5 5 0 0 1-10 0c0-2 1-3.8 2.4-5.2C11 7 11.7 4.6 12 3z"/></svg></div><h4>PR-Texte</h4><p>Public-Relations-Texte, die Bekanntmachungen und Botschaften der Wettbewerber zeigen.</p></div>
      <div class="cell"><div class="ix">03</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20v-7a5 5 0 0 1 10 0v7"/><path d="M5.5 20H8M16 20h2.5"/><circle cx="8.2" cy="11" r=".6"/><circle cx="8.5" cy="14.5" r=".6"/><circle cx="15.8" cy="11" r=".6"/><circle cx="15.5" cy="14.5" r=".6"/></svg></div><h4>Newsletter</h4><p>50 digital erfasste Verlags-Newsletter als Teil der transparenten Sicht.</p></div>
      <div class="cell"><div class="ix">04</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/></svg></div><h4>Spendings</h4><p>Werbespendings werden mithilfe der Mediadaten der Verlage hinterlegt.</p></div>
    </div>
  </div>
</section>

<!-- USE CASES -->
<section>
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(03)</span> Anwendungen im Dental-Marketing</div>
      <h2>Wofür Dental-Teams BrandFacts nutzen</h2>
    </div>
    <div class="rows reveal">
      <a class="ucrow" href="/#usecases"><div class="ix">01</div><div><h4>Wettbewerbsanalyse</h4><p>Relevante Werbeaktivitäten der Konkurrenz im Dentalmarkt auf einen Blick — transparent statt Bauchgefühl.</p></div><div class="go">→</div></a>
      <a class="ucrow" href="/#usecases"><div class="ix">02</div><div><h4>Mediaplanung</h4><p>Budget passgenauer verteilen — auf Basis dessen, wo und wie Ihre Wettbewerber im Dentalmarkt werben.</p></div><div class="go">→</div></a>
      <a class="ucrow" href="/#usecases"><div class="ix">03</div><div><h4>Kampagnenentwicklung</h4><p>Entwickeln Sie einzigartige Anzeigenschaltungen, die Ihre Zielgruppe im Dentalbereich wirklich ansprechen.</p></div><div class="go">→</div></a>
    </div>
  </div>
</section>

<!-- FORGE BAND -->
  <section>
    <div class="wrap">
      <div class="forge-band reveal">
        <img src="/img/forge-dental.webp" alt="FaktenSchmied — entspannt am Ofen: mit BrandFacts bleibt der Überblick über den Dentalmarkt mühelos." width="1200" height="800" loading="lazy" />
        <div class="cap"><div class="t">„Entspannt den Überblick behalten."</div><div class="s">// Anzeigen, PR und Spendings im Dentalmarkt — strukturiert nach Produktkategorien.</div></div>
      </div>
    </div>
  </section>

<!-- FINAL CTA -->
<div class="final"><div class="wrap"><div class="cta reveal">
  <div class="mesh"></div>
  <h2>Behalten Sie den Dentalmarkt im Blick.</h2>
  <p>In einer kostenlosen Demo zeigen wir BrandFacts an Ihren Produktkategorien und Ihrem Wettbewerbsumfeld.</p>
  <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Dental-Demo anfragen <span class="ar">→</span></span></a></div>
</div></div></div>

<!-- FOOTER -->
</Base>
