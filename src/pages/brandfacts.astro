---
import Base from '../layouts/Base.astro';
const jsonLd = [
  {"@context":"https://schema.org","@type":"SoftwareApplication","name":"BrandFacts","applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR","description":"Demo auf Anfrage"},"publisher":{"@type":"Organization","name":"FaktenSchmied GmbH","address":{"@type":"PostalAddress","streetAddress":"Bahnhofstraße 2","postalCode":"91522","addressLocality":"Ansbach","addressCountry":"DE"}},"description":"Healthcare-Werbemonitoring: Analyse von Werbedruck, Werbeinhalten und Werbespendings über Fachzeitschriften und Newsletter in Print und Digital."},
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Start","item":"https://www.faktenschmied.de/"},{"@type":"ListItem","position":2,"name":"BrandFacts","item":"https://www.faktenschmied.de/brandfacts"}]}
];
---
<Base title='BrandFacts — Healthcare-Werbemonitoring in Print & Digital | FaktenSchmied' description='BrandFacts analysiert Werbedruck, Werbeinhalte und Werbespendings im Healthcare-Markt — über 830 Fachzeitschriften und 580 Newsletter, filterbar nach Medium, Branche und Zeitraum. Demo anfragen.' path="/brandfacts" active="brandfacts" jsonLd={jsonLd}>
<!-- HERO -->
<section class="hero interior home">
  <div class="mesh"></div><div class="grain"></div>
  <div class="wrap">
    <div>
      <div class="crumb reveal"><a href="/">Start</a><span class="sep">/</span>BrandFacts</div>
      <img class="prod-mark reveal" src="/img/brandfacts-mark.png" alt="BrandFacts — Produktlogo" width="120" height="120" />
      <div class="ey on-dark reveal">Die Produktplattform</div>
      <h1 class="reveal" style="transition-delay:.08s">BrandFacts — <span class="serif-it o">sehen, wie der Markt wirbt.</span></h1>
      <p class="sub reveal" style="transition-delay:.16s">Eine Plattform für Healthcare-Werbemonitoring: Werbedruck, Werbeinhalte und Werbespendings über Fachzeitschriften und Newsletter, in Print und Digital — filterbar nach Medium, Branche und Zeitraum.</p>
      <div class="acts reveal" style="transition-delay:.24s">
        <a class="btn btn-primary btn-lg" href="/demo" id="magnet"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/methodik"><span class="lbl">Zur Methodik</span></a>
      </div>
    </div>
    <div class="reveal" style="transition-delay:.2s">
      <div class="glass" id="tilt" aria-hidden="true">
        <div class="gh"><i></i><i></i><i></i><span class="t">brandfacts › spendings · zeitraum</span></div>
        <div class="gb">
          <div class="gr"><span>Print</span><span>62%</span></div><div class="gbar"><span data-w="62%" style="background:var(--brand)"></span></div>
          <div class="gr"><span>Digital / Newsletter</span><span>38%</span></div><div class="gbar"><span data-w="38%" style="background:var(--viz-2)"></span></div>
          <div class="gchart"><i class="c" data-h="48%"></i><i class="c" data-h="66%"></i><i class="c" data-h="58%"></i><i class="c" data-h="80%"></i><i class="c" data-h="92%"></i><i class="c" data-h="74%"></i></div>
        </div>
      </div>
      <div class="chip"><span class="v">830</span><span class="k">Fachzeitschriften<br>+ 580 Newsletter</span></div>
    </div>
  </div>
</section>

<!-- PROOF -->
<div class="proof">
  <div class="wrap">
    <div class="it reveal"><div class="n"><span data-count="830">0</span></div><div class="l">Healthcare-Fachzeitschriften</div></div>
    <div class="it reveal" style="transition-delay:.08s"><div class="n"><span data-count="580">0</span></div><div class="l">erfasste Newsletter</div></div>
    <div class="it reveal" style="transition-delay:.16s"><div class="n">Print<span class="u">+</span>Digital</div><div class="l">durchgängige Abdeckung</div></div>
    <div class="it reveal" style="transition-delay:.24s"><div class="n">DACH</div><div class="l">Rx · Dental · Veterinär</div></div>
  </div>
</div>

<!-- WHAT IT IS -->
<section>
  <div class="wrap split top">
    <div class="reveal">
      <div class="ey"><span class="ix">(01)</span> Was BrandFacts ist</div>
      <h2 style="margin-top:18px">Ein vollständiges Bild des Werbemarkts — an einer Stelle.</h2>
      <p class="big">BrandFacts erfasst Anzeigenmotive, PR-Texte und Mediadaten systematisch, ordnet sie nach Markt und Kategorie zu und macht sie vergleichbar. Statt einzelner Beobachtungen entsteht eine belastbare Sicht auf <b>Werbedruck, Inhalte und Spendings</b> Ihrer Wettbewerber.</p>
      <p class="big">Sie filtern auf das, was für Sie zählt — nach Branche, Produktkategorie, Indikation oder Zeitraum — und überführen die Ergebnisse direkt in Budget-, Media- und Kampagnenentscheidungen.</p>
      <a class="btn btn-line" style="margin-top:14px" href="/methodik"><span class="lbl">Wie wir Daten erfassen <span class="ar">→</span></span></a>
    </div>
    <div class="reveal" style="transition-delay:.12s">
      <div class="panel">
        <div class="ph"><span class="t">brandfacts · werbedruck · zeitverlauf</span><span class="seg"><b class="on">Print</b><b>Digital</b></span></div>
        <div class="schem">
          <div class="schem-plot">
            <div class="schem-grp"><span class="sb b" style="height:42%"></span><span class="sb a" style="height:56%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:50%"></span><span class="sb a" style="height:48%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:46%"></span><span class="sb a" style="height:66%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:58%"></span><span class="sb a" style="height:74%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:52%"></span><span class="sb a" style="height:86%"></span></div>
            <div class="schem-grp"><span class="sb b" style="height:64%"></span><span class="sb a" style="height:95%"></span></div>
          </div>
          <div class="schem-foot"><span class="schem-leg"><i class="a"></i>Ihre Marke</span><span class="schem-leg"><i class="b"></i>Wettbewerb</span><span class="schem-time">Zeitverlauf →</span></div>
        </div>
        <div class="cap">// schematische Darstellung</div>
      </div>
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section class="feat">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(02)</span> Funktionen</div>
      <h2>Alles, was Werbemonitoring belastbar macht</h2>
      <p>Fünf Kernfunktionen, die Beobachtung in Entscheidungen übersetzen.</p>
    </div>
    <div class="bento reveal">
      <div class="cell"><div class="ix">01</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586z"/></svg></div><h4>Werbedruck</h4><p>Sehen Sie, wann Ihre Konkurrenten in welchem Medium präsent sind — und das über die letzten fünf Jahre.</p></div>
      <div class="cell"><div class="ix">02</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/></svg></div><h4>Werbespendings</h4><p>Mithilfe der hinterlegten Mediadaten der Verlage die Werbeausgaben Ihrer Wettbewerber analysieren und Budgets effektiv planen.</p></div>
      <div class="cell"><div class="ix">03</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c1.8 2.6 .6 4.6 0 5.6 .9-.4 1.8-1.6 2-2.6 1.8 1.8 3 4 3 6.4a5 5 0 0 1-10 0c0-2 1-3.8 2.4-5.2C11 7 11.7 4.6 12 3z"/></svg></div><h4>Werbeinhalte &amp; Key Visuals</h4><p>Botschaften und Anzeigenmotive der Mitbewerber auswerten und die Grundlage für eine klare Differenzierung schaffen.</p></div>
      <div class="cell"><div class="ix">04</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg></div><h4>Prozessoptimierung</h4><p>Genau die Daten, die Sie brauchen: Filtern Sie nach Präparaten, ATC-Codes oder Indikationen — und erhalten eine Datenbank nach Ihren Wünschen.</p></div>
      <div class="cell"><div class="ix">05</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20v-7a5 5 0 0 1 10 0v7"/><path d="M5.5 20H8M16 20h2.5"/><circle cx="8.2" cy="11" r=".6"/><circle cx="8.5" cy="14.5" r=".6"/><circle cx="15.8" cy="11" r=".6"/><circle cx="15.5" cy="14.5" r=".6"/></svg></div><h4>Print + Digital</h4><p>Konstante Analyse der Anzeigen, PR- &amp; CP-Texte sowie der Verlags-Newsletter.</p></div>
      <a class="cell cta-tile" href="/demo"><div class="ix">→</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m10 9 5 3-5 3z" fill="currentColor" stroke="none"/></svg></div><h4>BrandFacts live erleben</h4><p>In einer kostenlosen Demo an Ihren Fragestellungen — unverbindlich.</p><span class="cta-go">Demo anfragen →</span></a>
    </div>
  </div>
</section>

<!-- WHAT'S INSIDE -->
<section>
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(03)</span> Was enthalten ist</div>
      <h2>Eine breite, gepflegte Datenbasis</h2>
    </div>
    <div class="tiles">
      <div class="tile reveal"><div class="n">830</div><div class="l">Healthcare-Fachzeitschriften · DACH</div></div>
      <div class="tile reveal" style="transition-delay:.08s"><div class="n">580</div><div class="l">erfasste Verlags-Newsletter</div></div>
      <div class="tile reveal" style="transition-delay:.16s"><div class="n">Print<span class="u"> + </span>Digital</div><div class="l">Anzeigen · Advertorials · PR · Sonderveröffentlichungen</div></div>
    </div>
  </div>
</section>

<!-- INDUSTRY MODULES -->
<section class="feat" id="branchen">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(04)</span> Branchenmodule</div>
      <h2>Eine Plattform, drei Datenlogiken</h2>
      <p>Rx, Dental und Veterinär mit eigener Medien-, Kategorie- und Suchlogik.</p>
    </div>
    <div class="ind">
      <div class="icard reveal"><div class="glow"></div>
        <div class="ic-h"><span class="tg">Rx</span><h4>Rx-Werbemonitoring</h4></div>
        <div class="ic-b"><dl>
          <div class="row"><dt>Fachzeitschriften</dt><dd><span class="ac">&gt;700</span></dd></div>
          <div class="row"><dt>Verlags-Newsletter</dt><dd><span class="ac">&gt;540</span></dd></div>
          <div class="row"><dt>Zuordnung</dt><dd>ATC-Code</dd></div>
          <div class="row"><dt>Filter</dt><dd>Indikation</dd></div>
        </dl></div>
        <div class="ic-f"><a href="/brandfacts/rx-werbemonitoring">Zur Rx-Lösung <span class="ar">→</span></a></div>
      </div>
      <div class="icard reveal" style="transition-delay:.1s"><div class="glow"></div>
        <div class="ic-h"><span class="tg">Dental</span><h4>Dental-Werbemonitoring</h4></div>
        <div class="ic-b"><dl>
          <div class="row"><dt>Dentalfachtitel</dt><dd><span class="ac">100</span></dd></div>
          <div class="row"><dt>Verlags-Newsletter</dt><dd><span class="ac">50</span></dd></div>
          <div class="row"><dt>Inhalte</dt><dd>Anzeigen + PR</dd></div>
          <div class="row"><dt>Struktur</dt><dd>Produktkategorien</dd></div>
        </dl></div>
        <div class="ic-f"><a href="/brandfacts/dental-werbemonitoring">Zur Dental-Lösung <span class="ar">→</span></a></div>
      </div>
      <div class="icard reveal" style="transition-delay:.2s"><div class="glow"></div>
        <div class="ic-h"><span class="tg">Veterinär</span><h4>Veterinär-Werbemonitoring</h4></div>
        <div class="ic-b"><dl>
          <div class="row"><dt>Markt</dt><dd>Tiergesundheit</dd></div>
          <div class="row"><dt>Methodik</dt><dd>wie Rx / Dental</dd></div>
          <div class="row"><dt>Medien</dt><dd>Print + Digital</dd></div>
          <div class="row"><dt>Datenabdeckung</dt><dd><span class="ac">auf Anfrage</span></dd></div>
        </dl></div>
        <div class="ic-f"><a href="/demo">Abdeckung anfragen <span class="ar">→</span></a></div>
      </div>
    </div>
  </div>
</section>

<!-- HOW A DEMO WORKS -->
<section>
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="ey"><span class="ix">(05)</span> Ablauf</div>
      <h2>Von der Anfrage zum Einblick</h2>
    </div>
    <div class="steps reveal">
      <div class="step"><div class="num"></div><h4>Anfrage</h4><p>Kurzes Formular — Branche und Anliegen genügen für den Start.</p></div>
      <div class="step"><div class="num"></div><h4>Bedarf klären</h4><p>Wir verstehen Markt, Wettbewerber und Ihre konkreten Fragen.</p></div>
      <div class="step"><div class="num"></div><h4>Live-Demo</h4><p>BrandFacts an Ihren Beispielen im kostenlosen Teams-Meeting.</p></div>
      <div class="step"><div class="num"></div><h4>Zuschnitt</h4><p>Individuelle Auswahl der Segmente, die für Sie relevant sind.</p></div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="final"><div class="wrap"><div class="cta reveal">
  <div class="mesh"></div>
  <h2>Bereit, Ihren Markt zu sehen?</h2>
  <p>In einer kostenlosen Demo zeigen wir Ihnen BrandFacts an Ihren Fragestellungen — unverbindlich, in rund 30 Minuten.</p>
  <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a></div>
</div></div></div>

<!-- FOOTER -->
</Base>
