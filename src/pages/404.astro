---
import Base from '../layouts/Base.astro';
---
<Base title="Seite nicht gefunden | FaktenSchmied" description="Diese Seite existiert nicht. Zurück zur Startseite oder direkt zur Demo." path="/404">
  <section class="hero interior" style="min-height:70vh;display:flex;align-items:center">
    <div class="mesh"></div><div class="grain"></div>
    <div class="wrap">
      <div class="ey on-dark">Fehler 404</div>
      <h1 style="margin-top:14px">Diese Seite haben wir <span class="serif-it o">nicht gefunden.</span></h1>
      <p class="sub">Vielleicht hilft einer dieser Wege weiter — oder Sie fragen direkt eine Demo an.</p>
      <div class="acts">
        <a class="btn btn-primary btn-lg" href="/"><span class="lbl">Zur Startseite <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/brandfacts"><span class="lbl">BrandFacts</span></a>
        <a class="btn btn-onnavy btn-lg" href="/demo"><span class="lbl">Demo anfragen</span></a>
      </div>
    </div>
  </section>
</Base>
