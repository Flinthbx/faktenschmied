---
import Base from '../layouts/Base.astro';
---
<Base title='Über uns | FaktenSchmied GmbH, Ansbach' description='FaktenSchmied aus Ansbach: spezialisiert auf Healthcare-Werbemonitoring. Persönliche Ansprechpartner für Rx, Dental und Veterinär.' path="/ueber-uns" active="">
  <section class="hero interior">
    <div class="mesh"></div><div class="grain"></div>
    <div class="wrap">
      <div class="ey on-dark reveal">Über uns</div>
      <h1 class="reveal" style="transition-delay:.08s">Spezialisiert auf <span class="serif-it o">Healthcare-Werbemonitoring.</span></h1>
      <p class="sub reveal" style="transition-delay:.16s">FaktenSchmied entwickelt mit BrandFacts Werbemonitoring für den Healthcare-Markt — mit persönlichen Ansprechpartnern und fachlicher Nähe zu Rx, Dental und Veterinär.</p>
      <div class="acts reveal" style="transition-delay:.24s">
        <a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/brandfacts"><span class="lbl">BrandFacts</span></a>
      </div>
    </div>
  </section>
  <section><div class="wrap">
    <div class="tiles reveal">
      <div class="tile"><div class="n">Ansbach</div><div class="l">Bahnhofstraße 2 · 91522</div></div>
      <div class="tile"><div class="n">DACH</div><div class="l">Marktraum Rx · Dental · Veterinär</div></div>
      <div class="tile"><div class="n">Persönlich</div><div class="l">feste Ansprechpartner je Branche</div></div>
    </div></div></section>
  <div class="final"><div class="wrap"><div class="cta reveal">
    <div class="mesh"></div>
    <h2>Sehen Sie BrandFacts in Aktion.</h2>
    <p>In einer kostenlosen Demo zeigen wir Ihnen BrandFacts an Ihren Fragestellungen — unverbindlich.</p>
    <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a></div>
  </div></div></div>
</Base>
