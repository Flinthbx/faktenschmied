---
import Base from '../layouts/Base.astro';
---
<Base title='Datenschutz | FaktenSchmied GmbH' description='Datenschutzerklärung der FaktenSchmied GmbH (Platzhalter).' path="/datenschutz" active="">
  <section class="hero interior">
    <div class="mesh"></div><div class="grain"></div>
    <div class="wrap">
      <div class="ey on-dark reveal">Rechtliches</div>
      <h1 class="reveal" style="transition-delay:.08s">Datenschutz <span class="serif-it o">(Platzhalter).</span></h1>
      <p class="sub reveal" style="transition-delay:.16s">Diese Datenschutzerklärung ist ein Platzhalter und vor Launch juristisch zu finalisieren — inkl. Verantwortlichem, Verarbeitungszwecken, Rechtsgrundlagen, Newsletter-Double-Opt-in und Betroffenenrechten.</p>
      <div class="acts reveal" style="transition-delay:.24s">
        <a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a>
        <a class="btn btn-onnavy btn-lg" href="/brandfacts"><span class="lbl">BrandFacts</span></a>
      </div>
    </div>
  </section>

  <div class="final"><div class="wrap"><div class="cta reveal">
    <div class="mesh"></div>
    <h2>Sehen Sie BrandFacts in Aktion.</h2>
    <p>In einer kostenlosen Demo zeigen wir Ihnen BrandFacts an Ihren Fragestellungen — unverbindlich.</p>
    <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a></div>
  </div></div></div>
</Base>
