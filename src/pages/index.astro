---
import Base from '../layouts/Base.astro';
import HeroLoader from '../components/HeroLoader.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'FaktenSchmied GmbH',
    url: 'https://www.faktenschmied.de/',
    email: 'Jennifer.Raidel@faktenschmied.de',
    telephone: '+49-981-208-6261-0',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Bahnhofstraße 2',
      postalCode: '91522',
      addressLocality: 'Ansbach',
      addressCountry: 'DE',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'FaktenSchmied',
    url: 'https://www.faktenschmied.de/',
  },
];
---
<Base
  title="FaktenSchmied | Healthcare-Werbemonitoring mit BrandFacts"
  description="BrandFacts macht sichtbar, wie der Healthcare-Markt wirbt: Werbedruck, Werbeinhalte und Werbespendings über 830 Fachzeitschriften und 580 Newsletter in Print und Digital. Demo anfragen."
  path="/"
  jsonLd={jsonLd}
>
  <!-- INTRO LOADER (PRO Pack hero-9, keyword grid) -->
  <HeroLoader />

  <!-- HERO -->
  <section class="hero home">
    <div class="mesh"></div><div class="grain"></div>
    <div class="wrap">
      <div>
        <div class="ey reveal">Healthcare-Werbemonitoring</div>
        <h1 class="reveal" style="transition-delay:.08s">Sehen Sie, <span class="serif-it o">wie Ihr Markt wirbt</span> — bevor es Ihre Wettbewerber tun.</h1>
        <p class="sub reveal" style="transition-delay:.16s">BrandFacts analysiert den Werbedruck, Werbeinhalte und Werbespendings im Healthcare-Sektor für die Region D-A-CH. Erfasst werden die Fachzeitschriften sowie die Newsletter der Verlage. Mithilfe dieser Werbe-Beobachtung treffen Sie bessere Budget-, Kampagnen- und Positionierungsentscheidungen.</p>
        <div class="acts reveal" style="transition-delay:.24s">
          <a class="btn btn-primary btn-lg" href="/demo" id="magnet"><span class="lbl">Kostenlose Demo anfragen <span class="ar">→</span></span></a>
          <a class="btn btn-line btn-lg" href="/brandfacts"><span class="lbl">BrandFacts entdecken</span></a>
        </div>
        <div class="micro reveal" style="transition-delay:.32s"><span class="dot"></span>Kostenloses Teams-Meeting · Bedarf klären · unverbindlich</div>
      </div>
    </div>
    <div class="hero-visual reveal" style="transition-delay:.2s">
      <div class="hero-art">
        <svg class="hero-blob" viewBox="0 0 100 120" preserveAspectRatio="none" aria-hidden="true" focusable="false">
          <defs>
            <linearGradient id="heroNavy" x1="0.15" y1="0" x2="0.85" y2="1">
              <stop offset="0" stop-color="#202858" />
              <stop offset="0.55" stop-color="#15183B" />
              <stop offset="1" stop-color="#0c0f26" />
            </linearGradient>
          </defs>
          <path fill="url(#heroNavy)" d="M40,-6 C30,10 14,18 12,36 C10,52 30,54 26,70 C20,82 12,94 8,106 C4,120 -8,132 -18,146 L30,146 C42,132 52,120 56,106 C60,94 68,82 74,70 C70,54 60,56 64,40 C68,24 104,26 106,10 C108,2 110,-2 108,-6 Z" />
        </svg>
        <img src="/img/hero-anvil-trans.png" alt="Aus glühenden Rohdaten werden am Amboss belastbare Fakten geschmiedet — Hammer und Datenvisualisierungen über einem Amboss." width="816" height="828" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <div class="proof">
    <div class="wrap">
      <div class="it reveal"><div class="n"><span data-count="830">0</span></div><div class="l">Healthcare-Fachzeitschriften</div></div>
      <div class="it reveal" style="transition-delay:.08s"><div class="n"><span data-count="580">0</span></div><div class="l">erfasste Newsletter</div></div>
      <div class="it reveal" style="transition-delay:.16s"><div class="n">Print<span class="u">+</span>Digital</div><div class="l">durchgängige Abdeckung</div></div>
      <div class="it reveal" style="transition-delay:.24s"><div class="n">DACH</div><div class="l">Rx · Dental · Veterinär</div></div>
    </div>
  </div>

  <!-- PROBLEM / VALUE -->
  <section id="produkt">
    <div class="wrap split top">
      <div class="reveal">
        <div class="ey"><span class="ix">(01)</span> Das Problem</div>
        <h2 style="margin-top:18px">Budgetentscheidungen — ohne Transparenz auf dem Werbemarkt</h2>
        <p class="big">Für einen umfassenden Blick über den Markt müssen Tausende Werbeplatzierungen in Fachzeitschriften und Verlags-Newslettern für die Region D-A-CH gescreent, verglichen und analysiert werden.</p>
        <p class="big"><b>BrandFacts schließt diese Lücke.</b> Anzeigenmotive und Mediadaten werden systematisch erfasst, zugeordnet und dadurch vergleichbar gemacht.</p>
        <a class="btn btn-line" style="margin-top:14px" href="/methodik"><span class="lbl">Wie wir Daten erfassen <span class="ar">→</span></span></a>
      </div>
      <div class="reveal" style="transition-delay:.12s">
        <div class="panel">
          <div class="ph"><span class="t">werbedruck · wettbewerbsvergleich</span><span class="seg"><b class="on">Print</b><b>Digital</b></span></div>
          <div class="schem">
            <div class="schem-plot">
              <div class="schem-grp"><span class="sb b" style="height:40%"></span><span class="sb a" style="height:55%"></span></div>
              <div class="schem-grp"><span class="sb b" style="height:52%"></span><span class="sb a" style="height:47%"></span></div>
              <div class="schem-grp"><span class="sb b" style="height:46%"></span><span class="sb a" style="height:64%"></span></div>
              <div class="schem-grp"><span class="sb b" style="height:60%"></span><span class="sb a" style="height:72%"></span></div>
              <div class="schem-grp"><span class="sb b" style="height:54%"></span><span class="sb a" style="height:86%"></span></div>
              <div class="schem-grp"><span class="sb b" style="height:66%"></span><span class="sb a" style="height:96%"></span></div>
            </div>
            <div class="schem-foot"><span class="schem-leg"><i class="a"></i>Ihre Marke</span><span class="schem-leg"><i class="b"></i>Wettbewerb</span><span class="schem-time">Zeitverlauf →</span></div>
          </div>
          <div class="cap">// schematische Darstellung</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="feat">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="ey"><span class="ix">(02)</span> Was BrandFacts möglich macht</div>
        <h2>Fundierte Werbeanalysen in einem Tool</h2>
        <p>Minimierter Aufwand, belegbare Argumente, eine smarte Investition.</p>
      </div>
      <div class="bento reveal">
        <div class="cell"><div class="ix">01</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586z"/></svg></div><h4>Werbedruck</h4><p>Sehen Sie, wann Ihre Konkurrenten in welchem Medium präsent sind — und das über die letzten fünf Jahre.</p></div>
        <div class="cell"><div class="ix">02</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/></svg></div><h4>Werbespendings</h4><p>Mithilfe der hinterlegten Mediadaten der Verlage die Werbeausgaben Ihrer Wettbewerber analysieren und Budgets effektiv planen.</p></div>
        <div class="cell"><div class="ix">03</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c1.8 2.6 .6 4.6 0 5.6 .9-.4 1.8-1.6 2-2.6 1.8 1.8 3 4 3 6.4a5 5 0 0 1-10 0c0-2 1-3.8 2.4-5.2C11 7 11.7 4.6 12 3z"/></svg></div><h4>Werbeinhalte &amp; Key Visuals</h4><p>Botschaften und Anzeigenmotive der Mitbewerber auswerten und die Grundlage für eine klare Differenzierung schaffen.</p></div>
        <div class="cell"><div class="ix">04</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg></div><h4>Prozessoptimierung</h4><p>Genau die Daten, die Sie brauchen: Filtern Sie nach Präparaten, ATC-Codes oder Indikationen — und erhalten eine Datenbank nach Ihren Wünschen.</p></div>
        <div class="cell"><div class="ix">05</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20v-7a5 5 0 0 1 10 0v7"/><path d="M5.5 20H8M16 20h2.5"/><circle cx="8.2" cy="11" r=".6"/><circle cx="8.5" cy="14.5" r=".6"/><circle cx="15.8" cy="11" r=".6"/><circle cx="15.5" cy="14.5" r=".6"/></svg></div><h4>Print + Digital</h4><p>Konstante Analyse der Anzeigen, PR- &amp; CP-Texte sowie der Verlags-Newsletter.</p></div>
        <a class="cell cta-tile" href="/demo"><div class="ix">→</div><div class="ic"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m10 9 5 3-5 3z" fill="currentColor" stroke="none"/></svg></div><h4>BrandFacts live erleben</h4><p>In einer kostenlosen Demo an Ihren Fragestellungen — unverbindlich.</p><span class="cta-go">Demo anfragen →</span></a>
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section id="branchen">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="ey"><span class="ix">(03)</span> Branchen</div>
        <h2>Eigene Datenlogik für jeden Markt</h2>
        <p>Rx, Dental und Veterinär unterscheiden sich in Medien, Kategorien und Suchlogik. BrandFacts bildet das präzise ab.</p>
      </div>
      <div class="ind">
        <div class="icard reveal"><div class="glow"></div>
          <div class="ic-h"><span class="tg">Rx</span><h4>Rx-Werbemonitoring</h4></div>
          <div class="ic-b ic-stat"><div class="big"><span class="ac">&gt;700</span><small>Fachzeitschriften</small></div><div class="sub2">+ &gt;540 Verlags-Newsletter</div></div>
          <div class="ic-f"><a href="/brandfacts/rx-werbemonitoring">Zur Rx-Lösung <span class="ar">→</span></a></div>
        </div>
        <div class="icard reveal" style="transition-delay:.1s"><div class="glow"></div>
          <div class="ic-h"><span class="tg">Dental</span><h4>Dental-Werbemonitoring</h4></div>
          <div class="ic-b ic-stat"><div class="big"><span class="ac">100</span><small>Dentalfachtitel</small></div><div class="sub2">+ 50 Verlags-Newsletter</div></div>
          <div class="ic-f"><a href="/brandfacts/dental-werbemonitoring">Zur Dental-Lösung <span class="ar">→</span></a></div>
        </div>
        <div class="icard reveal" style="transition-delay:.2s"><div class="glow"></div>
          <div class="ic-h"><span class="tg">Veterinär</span><h4>Veterinär-Werbemonitoring</h4></div>
          <div class="ic-b ic-stat"><div class="big sm"><span class="ac">auf Anfrage</span><small>Datenabdeckung</small></div><div class="sub2">Methodik wie Rx &amp; Dental</div></div>
          <div class="ic-f"><a href="/demo">Abdeckung anfragen <span class="ar">→</span></a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="feat" id="usecases">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="ey"><span class="ix">(04)</span> Use Cases</div>
        <h2>Wofür Teams BrandFacts nutzen</h2>
      </div>
      <div class="rows reveal">
        <a class="ucrow" href="/use-cases/wettbewerbsanalyse"><div class="ix">01</div><div><h4>Wettbewerbsanalyse</h4><p>Sehen, wer wie viel, wo und mit welcher Botschaft wirbt — als belastbare Grundlage für die eigene Strategie.</p></div><div class="go">→</div></a>
        <a class="ucrow" href="/use-cases/mediaplanung"><div class="ix">02</div><div><h4>Mediaplanung</h4><p>Budgets, Medien und Zielgruppen auf Basis dessen planen, was im Markt tatsächlich passiert.</p></div><div class="go">→</div></a>
        <a class="ucrow" href="/use-cases/kampagnenentwicklung"><div class="ix">03</div><div><h4>Kampagnenentwicklung</h4><p>Botschaften und Key Visuals der Konkurrenz kennen — und die eigene Kampagne bewusst differenzieren.</p></div><div class="go">→</div></a>
      </div>
    </div>
  </section>

  <!-- METHODIK -->
  <section class="method" id="methodik">
    <div class="wrap split">
      <div class="reveal">
        <div class="ey on-dark"><span class="ix" style="color:var(--brand)">(05)</span> Vertrauen durch Methodik</div>
        <h2 style="margin-top:18px">Datenbasierte Entscheidungen statt Behauptungen</h2>
        <p class="big">Das FaktenSchmied-Team erfasst Anzeigen, PR-Texte und Newsletter systematisch, prüft und kategorisiert sie und hinterlegt die Mediadaten der Verlage.</p>
        <a class="btn btn-line" href="/methodik"><span class="lbl">Zur Methodik <span class="ar">→</span></span></a>
      </div>
      <div class="reveal" style="transition-delay:.12s">
        <div class="qforge">
          <img src="/img/forge-home.webp" alt="FaktenSchmied — Blick in die Schmiede am Ofen, sinnbildlich für die ruhige, methodische Aufbereitung von Daten." width="1120" height="760" loading="lazy" />
          <div class="q-ov">
            <p class="q">„Klarheit statt Bauchgefühl. BrandFacts analysiert, Sie entscheiden datenbasiert."</p>
            <div class="who">FaktenSchmied-Team · Ansbach</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM TEASER -->
  <section>
    <div class="wrap">
      <div class="sec-head center reveal" style="margin-bottom:40px">
        <div class="ey" style="justify-content:center">Das Team</div>
        <h2>Persönliche Ansprechpartner</h2>
        <p>Hinter FaktenSchmied steht ein eingespieltes Team aus Ansbach — mit festem Draht zu Ihren Fragen rund um Rx, Dental und Veterinär.</p>
      </div>
      <div class="reveal" style="display:flex;flex-direction:column;align-items:center;gap:24px">
        <div class="teamrow">
          <img class="av" src="/img/team-jennifer.webp" alt="Jennifer Raidel" width="66" height="66" loading="lazy" />
          <img class="av" src="/img/team-bernhard.webp" alt="Bernhard Hebel" width="66" height="66" loading="lazy" />
          <img class="av" src="/img/team-jana.webp" alt="Jana" width="66" height="66" loading="lazy" />
          <img class="av" src="/img/team-kerstin.webp" alt="Kerstin" width="66" height="66" loading="lazy" />
          <img class="av" src="/img/team-silvia.webp" alt="Silvia" width="66" height="66" loading="lazy" />
        </div>
        <a class="btn btn-line" href="/ueber-uns"><span class="lbl">Team kennenlernen <span class="ar">→</span></span></a>
      </div>
    </div>
  </section>

  <!-- DEMO -->
  <section class="demo" id="demo">
    <div class="wrap split">
      <div class="lead reveal">
        <div class="ey"><span class="ix">(06)</span> Demo</div>
        <h2 style="margin-top:18px">Lösen Sie mit BrandFacts Ihre Fragestellungen.</h2>
        <div class="exp">
          <div class="li"><span class="b">1</span><span><b>Individuellen Bedarf klären</b><span>Wir gehen gezielt auf Ihren Markt, Ihre Branche und Ihre Fragen ein.</span></span></div>
          <div class="li"><span class="b">2</span><span><b>Tool live erleben</b><span>BrandFacts anhand Ihrer Beispiele.</span></span></div>
          <div class="li"><span class="b">3</span><span><b>Nächste Schritte</b><span>Zugeschnittene Betreuung nach Ihrem Bedarf.</span></span></div>
        </div>
      </div>
      <div class="reveal" style="transition-delay:.12s">
        <form class="form js-demo" novalidate>
          <h3>Demo anfragen</h3>
          <div class="fsub">// antwort i. d. r. innerhalb eines werktags</div>
          <div class="grid2">
            <div class="fld"><input id="vn" name="vorname" placeholder=" " /><label for="vn">Vorname</label></div>
            <div class="fld"><input id="nn" name="nachname" placeholder=" " /><label for="nn">Nachname <span class="req">*</span></label></div>
          </div>
          <div class="fld"><input id="em" name="email" type="email" placeholder=" " /><label for="em">Geschäftliche E-Mail <span class="req">*</span></label></div>
          <div class="grid2">
            <div class="fld"><input id="fa" name="unternehmen" placeholder=" " /><label for="fa">Unternehmen</label></div>
            <div class="fld"><select id="br" name="branche" required><option value="" selected disabled hidden></option><option>Rx / Pharma</option><option>Dental</option><option>Veterinär</option><option>Agentur</option><option>Sonstiges</option></select><label for="br">Branche</label></div>
          </div>
          <div class="fld"><textarea id="ms" name="nachricht" placeholder=" "></textarea><label for="ms">Ihr Anliegen</label></div>
          <div class="consent"><input type="checkbox" id="cs" /><label for="cs">Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung der Anfrage zu. <span class="req">*</span></label></div>
          <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp" />
        <div class="form-status" role="status" aria-live="polite"></div>
        <button class="btn btn-primary btn-block btn-lg" type="submit"><span class="lbl">Demo anfragen <span class="ar">→</span></span></button>
          <div class="trustline"><span>DSGVO-konform</span><span>Spam-Schutz</span><span>kein Verkaufsdruck</span></div>
        </form>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <div class="final"><div class="wrap"><div class="cta reveal">
    <div class="mesh"></div>
    <h2>Sehen Sie, wie Ihr Markt wirbt.</h2>
    <p>In einer kostenlosen Demo zeigen wir Ihnen BrandFacts an Ihren Fragestellungen — unverbindlich, in rund 30 Minuten.</p>
    <div class="acts"><a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a></div>
  </div></div></div>
</Base>
