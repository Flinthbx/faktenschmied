---
import Base from '../../layouts/Base.astro';
import HomeBody from '../../components/HomeBody.astro';
import VariantSwitcher from '../../components/VariantSwitcher.astro';
import VariantStyles from '../../components/VariantStyles.astro';
---
<Base title="Variante 2 · Editorial | FaktenSchmied" description="Startseiten-Variante 2 — typografische, editoriale Bühne." path="/varianten/v2" active="">
  <VariantStyles />
  <section class="vh2">
    <div class="wrap">
      <div class="rule reveal"></div>
      <div class="kick">BrandFacts · D-A-CH</div>
      <div class="ey reveal">Healthcare-Werbemonitoring</div>
      <h1 class="reveal" style="transition-delay:.08s">Sehen Sie, <span class="serif-it o">wie Ihr Markt wirbt.</span></h1>
      <div class="grid">
        <div class="reveal" style="transition-delay:.16s">
          <p class="sub">BrandFacts analysiert Werbedruck, Werbeinhalte und Werbespendings im Healthcare-Sektor — über hunderte Fachzeitschriften und Verlags-Newsletter. So treffen Sie bessere Budget-, Kampagnen- und Positionierungsentscheidungen.</p>
          <div class="acts">
            <a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Kostenlose Demo anfragen <span class="ar">→</span></span></a>
            <a class="btn btn-line btn-lg" href="/brandfacts"><span class="lbl">BrandFacts entdecken</span></a>
          </div>
        </div>
        <div class="side reveal" style="transition-delay:.24s">
          <div class="k">„Aus Rohdaten werden belastbare Fakten."</div>
          <div class="s">Werbe-Beobachtung statt Bauchgefühl — bevor es Ihre Wettbewerber tun.</div>
        </div>
      </div>
    </div>
  </section>
  <HomeBody />
  <VariantSwitcher active="2" />
</Base>
