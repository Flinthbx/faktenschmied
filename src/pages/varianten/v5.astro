---
import Base from '../../layouts/Base.astro';
import HomeBody from '../../components/HomeBody.astro';
import VariantSwitcher from '../../components/VariantSwitcher.astro';
import VariantStyles from '../../components/VariantStyles.astro';
import FontSwitcher from '../../components/FontSwitcher.astro';
import FxTilt from '../../components/FxTilt.astro';
---
<Base title="Variante 5 · Split | FaktenSchmied" description="Startseiten-Variante 5 — heller Split mit Orange-Block." path="/varianten/v5" active="">
  <VariantStyles /><FontSwitcher />
  <section class="vh5">
    <div class="wrap">
      <div>
        <div class="ey reveal">Healthcare-Werbemonitoring</div>
        <h1 class="reveal" style="transition-delay:.08s">Sehen Sie, <span class="serif-it o">wie Ihr Markt wirbt</span> — bevor es Ihre Wettbewerber tun.</h1>
        <p class="sub reveal" style="transition-delay:.16s">BrandFacts analysiert Werbedruck, Werbeinhalte und Werbespendings im Healthcare-Sektor für D-A-CH — über Fachzeitschriften und Verlags-Newsletter. So treffen Sie bessere Budget-, Kampagnen- und Positionierungsentscheidungen.</p>
        <div class="acts reveal" style="transition-delay:.24s">
          <a class="btn btn-primary btn-lg" href="/demo"><span class="lbl">Kostenlose Demo anfragen <span class="ar">→</span></span></a>
          <a class="btn btn-line btn-lg" href="/brandfacts"><span class="lbl">BrandFacts entdecken</span></a>
        </div>
        <div class="vh-micro reveal" style="transition-delay:.32s"><span class="dot"></span>Kostenloses Teams-Meeting · Bedarf klären · unverbindlich</div>
      </div>
      <div class="reveal" style="transition-delay:.2s">
        <div class="shot fx-tilt">
          <div class="blk"></div>
          <img src="/img/forge-jennifer.webp" alt="FaktenSchmied — am Amboss wird aus glühendem Material Form geschmiedet: aus Rohdaten werden belastbare Fakten." width="880" height="1100" loading="eager" />
          <span class="badge">Aus Rohdaten Fakten schmieden</span>
        </div>
      </div>
    </div>
  </section>
  <HomeBody />
  <FxTilt />
  <VariantSwitcher active="5" />
</Base>
