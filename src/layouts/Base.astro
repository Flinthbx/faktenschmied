---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/inter/900.css';
import '@fontsource/source-serif-4/400-italic.css';

export interface Props {
  title: string;
  description: string;
  /** Pfad ohne Domain, z.B. "/brandfacts" */
  path?: string;
  jsonLd?: Record<string, unknown>[];
  /** key der aktiven Navi: brandfacts | branchen | usecases | methodik | insights */
  active?: string;
}

const { title, description, path = '/', jsonLd = [], active = '' } = Astro.props;
const canonical = new URL(path, Astro.site ?? 'https://www.faktenschmied.de').href;
const ogImage = 'https://www.faktenschmied.de/og-default.png';

const nav = [
  { key: 'brandfacts', label: 'BrandFacts', href: '/brandfacts' },
  { key: 'usecases', label: 'Use Cases', href: '/use-cases/wettbewerbsanalyse' },
  { key: 'insights', label: 'Insights', href: '/insights' },
];
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index,follow" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="FaktenSchmied" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#15183B" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  {jsonLd.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))}
</head>
<body>
  <div id="prog"></div>

  <nav class="site-menu" id="siteMenu" aria-label="Hauptnavigation">
    <div class="menu-bar" id="hdr">
      <a class="logo" href="/" aria-label="FaktenSchmied — zur Startseite">
        <img src="/img/logo.png" alt="FaktenSchmied" width="167" height="96" />
      </a>
      <button class="menu-toggle-btn" id="menuToggle" type="button" aria-expanded="false" aria-controls="menuOverlay" aria-label="Menü öffnen">
        <span class="menu-toggle-label">
          <span class="ml ml-open">Menü</span>
          <span class="ml ml-close">Schließen</span>
        </span>
        <span class="menu-hamburger-icon" aria-hidden="true"><span></span><span></span></span>
      </button>
    </div>

    <div class="menu-overlay" id="menuOverlay">
      <div class="menu-overlay-content">
        <div class="menu-media-wrapper">
          <img src="/img/forge-jennifer.webp" alt="" loading="lazy" />
        </div>
        <div class="menu-content-wrapper">
          <div class="menu-content-main">
            <div class="menu-col menu-col-main">
              {nav.map((n) => (
                <div class="menu-link"><a href={n.href} aria-current={active === n.key ? 'page' : undefined}>{n.label}</a></div>
              ))}
            </div>
            <div class="menu-col menu-col-sub">
              <div class="menu-tag"><a href="/brandfacts/rx-werbemonitoring">Rx-Werbemonitoring</a></div>
              <div class="menu-tag"><a href="/brandfacts/dental-werbemonitoring">Dental-Werbemonitoring</a></div>
              <div class="menu-tag"><a href="/brandfacts/veterinaer-werbemonitoring">Veterinär-Werbemonitoring</a></div>
              <div class="menu-cta"><a class="btn btn-primary" href="/demo"><span class="lbl">Demo anfragen <span class="ar">→</span></span></a></div>
            </div>
          </div>
          <div class="menu-footer">
            <div class="menu-col">
              <p>FaktenSchmied GmbH</p>
              <p>Bahnhofstraße 2 · 91522 Ansbach</p>
            </div>
            <div class="menu-col">
              <p><a href="tel:+4998120862610">+49 (0) 981 208 6261-0</a></p>
              <p><a href="mailto:Jennifer.Raidel@faktenschmied.de">Jennifer.Raidel@faktenschmied.de</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <div class="page-container" id="pageContainer">
  <main>
    <slot />
  </main>

  <footer class="site">
    <div class="wrap">
      <div class="top">
        <div>
          <a class="logo" href="/"><img src="/img/logo.png" alt="FaktenSchmied" width="167" height="96" /></a>
          <p class="desc">Healthcare-Werbemonitoring aus Ansbach. BrandFacts macht sichtbar, wie der Markt wirbt — über Print und Digital.</p>
        </div>
        <div>
          <h5>Produkt</h5>
          <ul>
            <li><a href="/brandfacts">BrandFacts</a></li>
            <li><a href="/brandfacts/rx-werbemonitoring">Rx-Werbemonitoring</a></li>
            <li><a href="/brandfacts/dental-werbemonitoring">Dental-Werbemonitoring</a></li>
            <li><a href="/brandfacts/veterinaer-werbemonitoring">Veterinär-Werbemonitoring</a></li>
          </ul>
        </div>
        <div>
          <h5>Use Cases</h5>
          <ul>
            <li><a href="/use-cases/wettbewerbsanalyse">Wettbewerbsanalyse</a></li>
            <li><a href="/use-cases/mediaplanung">Mediaplanung</a></li>
            <li><a href="/use-cases/kampagnenentwicklung">Kampagnenentwicklung</a></li>
            <li><a href="/methodik">Methodik</a></li>
            <li><a href="/insights">Insights</a></li>
          </ul>
        </div>
        <div class="nl">
          <h5>Newsletter</h5>
          <p class="desc" style="margin-bottom:14px">Marktbeobachtung, regelmäßig in Ihr Postfach.</p>
          <form method="post" action="#" onsubmit="return false">
            <input placeholder="Geschäftliche E-Mail" aria-label="E-Mail" type="email" />
            <button class="btn btn-primary btn-block" style="margin-top:10px"><span class="lbl">Abonnieren <span class="ar">→</span></span></button>
          </form>
          <p style="font-family:var(--mono);font-size:10.5px;margin-top:10px;color:#838AC0">// double-opt-in · abmeldung jederzeit</p>
        </div>
      </div>
      <div class="legal">
        <span>© 2026 FaktenSchmied GmbH · Bahnhofstraße 2, 91522 Ansbach · +49 (0) 981 208 6261-0</span>
        <span><a href="/impressum">Impressum</a> · <a href="/datenschutz">Datenschutz</a> · <a href="/demo">Kontakt</a></span>
      </div>
    </div>
  </footer>
  </div>

  <script>
    const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const hdr = document.getElementById('hdr');
    const prog = document.getElementById('prog');
    function onScroll() {
      const y = window.scrollY;
      if (hdr) hdr.classList.toggle('scrolled', y > 40);
      if (prog) {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        prog.style.width = (h > 0 ? (y / h) * 100 : 0) + '%';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    function count(el) {
      if (el.dataset.done) return; el.dataset.done = '1';
      const target = +el.dataset.count;
      if (RM) { el.textContent = String(target); return; }
      const dur = 1400, t0 = performance.now();
      function step(t) {
        const p = Math.min((t - t0) / dur, 1), e = 1 - Math.pow(1 - p, 3);
        el.textContent = String(Math.round(target * e));
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    function activate(el) {
      el.classList.add('in');
      el.querySelectorAll('[data-count]').forEach(count);
      if (el.matches('[data-count]')) count(el);
      el.querySelectorAll('.gbar>span[data-w]').forEach((s) => (s.style.width = s.dataset.w));
      el.querySelectorAll('.gchart .c[data-h]').forEach((s) => (s.style.height = s.dataset.h));
    }
    const io = new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting) { activate(e.target); io.unobserve(e.target); } });
    }, { threshold: 0.18 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

    window.addEventListener('load', () => setTimeout(() => {
      document.querySelectorAll('.gbar>span[data-w]').forEach((s) => (s.style.width = s.dataset.w));
      document.querySelectorAll('.gchart .c[data-h]').forEach((s) => (s.style.height = s.dataset.h));
    }, 300));

    const fine = matchMedia('(pointer:fine)').matches;
    const mag = document.getElementById('magnet');
    if (mag && !RM && fine) {
      const str = 22;
      mag.addEventListener('mousemove', (e) => {
        const r = mag.getBoundingClientRect();
        const x = ((e.clientX - r.left - r.width / 2) / r.width) * str;
        const y = ((e.clientY - r.top - r.height / 2) / r.height) * str;
        mag.style.transform = `translate(${x}px,${y}px)`;
      });
      mag.addEventListener('mouseleave', () => (mag.style.transform = ''));
    }
    const tilt = document.getElementById('tilt');
    if (tilt && !RM && fine) {
      const host = tilt.closest('section');
      host.addEventListener('mousemove', (e) => {
        const r = host.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        tilt.style.transform = `perspective(900px) rotateY(${px * 6}deg) rotateX(${-py * 6}deg)`;
      });
      host.addEventListener('mouseleave', () => (tilt.style.transform = ''));
    }
  </script>
  <div class="consent-bar" id="consentbar" hidden>
    <div class="cb-inner">
      <p>Wir verwenden nur technisch notwendige Cookies. Optionale Statistik-Cookies setzen wir erst nach Ihrer Einwilligung. <a href="/datenschutz">Mehr im Datenschutz</a>.</p>
      <div class="cb-acts">
        <button class="btn btn-line" id="cb-ess"><span class="lbl">Nur notwendige</span></button>
        <button class="btn btn-primary" id="cb-all"><span class="lbl">Alle akzeptieren</span></button>
      </div>
    </div>
  </div>
  <script>
    (function () {
      var KEY = 'fs-consent';
      var bar = document.getElementById('consentbar');
      if (!bar) return;
      try { if (localStorage.getItem(KEY)) return; } catch (e) {}
      bar.hidden = false;
      function choose(v) { try { localStorage.setItem(KEY, v); } catch (e) {} bar.hidden = true; }
      document.getElementById('cb-ess').addEventListener('click', function () { choose('essential'); });
      document.getElementById('cb-all').addEventListener('click', function () { choose('all'); });
    })();
  </script>
  <script>
    document.querySelectorAll('form.js-demo').forEach((f) => {
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        const status = f.querySelector('.form-status');
        const btn = f.querySelector('button[type="submit"], button');
        const cs = f.querySelector('#cs');
        if (cs && !cs.checked) { status.textContent = 'Bitte bestätigen Sie die Datenschutzerklärung.'; status.className = 'form-status err'; return; }
        const data = Object.fromEntries(new FormData(f).entries());
        btn.disabled = true; status.textContent = 'Wird gesendet …'; status.className = 'form-status';
        try {
          const r = await fetch('/api/demo', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          const j = await r.json().catch(() => ({ ok: false }));
          if (r.ok && j.ok) { f.reset(); status.textContent = 'Vielen Dank! Wir melden uns in der Regel innerhalb eines Werktags.'; status.className = 'form-status ok'; }
          else { status.textContent = (j && j.error) || 'Senden fehlgeschlagen. Bitte versuchen Sie es erneut.'; status.className = 'form-status err'; }
        } catch { status.textContent = 'Netzwerkfehler. Bitte später erneut versuchen.'; status.className = 'form-status err'; }
        btn.disabled = false;
      });
    });
  </script>

  <!-- Full-screen overlay menu (GSAP) -->
  <script>
    import gsap from 'gsap';
    import { SplitText } from 'gsap/SplitText';
    import { CustomEase } from 'gsap/CustomEase';

    const RMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const menu = document.getElementById('siteMenu');
    const toggle = document.getElementById('menuToggle');
    const overlay = document.getElementById('menuOverlay');

    if (menu && toggle && overlay) {
      const overlayContent = menu.querySelector('.menu-overlay-content');
      const mediaWrapper = menu.querySelector('.menu-media-wrapper');
      const pageContainer = document.getElementById('pageContainer');
      const splitTargets = menu.querySelectorAll('.menu-link a, .menu-tag a, .menu-footer p');

      let isOpen = false;
      let isAnimating = false;

      const lockScroll = (lock) => {
        document.documentElement.classList.toggle('no-scroll', lock);
        document.body.classList.toggle('no-scroll', lock);
      };
      const setState = (open) => {
        isOpen = open;
        menu.classList.toggle('is-open', open);
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
      };

      if (RMq.matches) {
        // Reduced motion: instant open/close, no animation.
        const open = () => { setState(true); menu.classList.add('rm-open'); lockScroll(true); };
        const close = () => { setState(false); menu.classList.remove('rm-open'); lockScroll(false); };
        toggle.addEventListener('click', () => (isOpen ? close() : open()));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) { close(); toggle.focus(); } });
      } else {
        gsap.registerPlugin(SplitText, CustomEase);
        CustomEase.create('hop', '.87,0,.13,1');

        // Initial (closed) states owned by GSAP so they don't clash with CSS transforms.
        gsap.set(overlay, { clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)' });
        gsap.set(overlayContent, { yPercent: -50 });
        gsap.set(mediaWrapper, { opacity: 0 });

        let splits = [];
        const buildSplits = () => {
          splits.forEach((s) => s.revert());
          splits = [];
          splitTargets.forEach((el) => {
            const split = SplitText.create(el, { type: 'lines', mask: 'lines', linesClass: 'split-line' });
            gsap.set(split.lines, { yPercent: -110 });
            splits.push(split);
          });
        };
        buildSplits();
        let rt;
        window.addEventListener('resize', () => {
          clearTimeout(rt);
          rt = setTimeout(() => { if (!isOpen && !isAnimating) buildSplits(); }, 200);
        });
        const allLines = () => splits.flatMap((s) => s.lines);

        const open = () => {
          if (isAnimating || isOpen) return;
          isAnimating = true;
          setState(true);
          lockScroll(true);
          const tl = gsap.timeline({ onComplete: () => { isAnimating = false; } });
          tl.to(pageContainer, { y: () => window.innerHeight, duration: 1, ease: 'hop' }, 0)
            .to(overlay, { clipPath: 'polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)', duration: 1, ease: 'hop' }, 0)
            .to(overlayContent, { yPercent: 0, duration: 1, ease: 'hop' }, 0)
            .to(mediaWrapper, { opacity: 1, duration: 0.75, ease: 'power2.out' }, 0.5)
            .to(allLines(), { yPercent: 0, duration: 1.3, ease: 'hop', stagger: 0.05 }, 0.25);
        };
        const close = () => {
          if (isAnimating || !isOpen) return;
          isAnimating = true;
          setState(false);
          const tl = gsap.timeline({
            onComplete: () => {
              gsap.set(allLines(), { yPercent: -110 });
              gsap.set(mediaWrapper, { opacity: 0 });
              // Remove the inline transform entirely: an identity transform on the
              // page wrapper still creates a containing block, which breaks
              // ScrollTrigger's position:fixed pin (e.g. the homepage spotlight).
              gsap.set(pageContainer, { clearProps: 'transform' });
              lockScroll(false);
              isAnimating = false;
            },
          });
          tl.to(pageContainer, { y: 0, duration: 0.9, ease: 'hop' }, 0)
            .to(overlay, { clipPath: 'polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)', duration: 0.9, ease: 'hop' }, 0)
            .to(overlayContent, { yPercent: -50, duration: 0.9, ease: 'hop' }, 0)
            .to(allLines(), { yPercent: -110, duration: 0.5, ease: 'hop' }, 0);
        };

        toggle.addEventListener('click', () => (isOpen ? close() : open()));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) { close(); toggle.focus(); } });
      }
    }
  </script>

  <!-- Scribble hover (GSAP) — strokes draw on over [data-scribble] cards -->
  <script>
    import gsap from 'gsap';

    const fine = window.matchMedia('(pointer:fine)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cards = document.querySelectorAll('[data-scribble]');

    if (cards.length && fine && !reduce) {
      cards.forEach((card) => {
        const paths = card.querySelectorAll('.scribble-layer path');
        if (!paths.length) return;

        const lengths = [];
        paths.forEach((p) => {
          const len = p.getTotalLength();
          lengths.push(len);
          p.style.strokeDasharray = String(len);
          p.style.strokeDashoffset = String(len); // hidden until hover
        });

        let tl = null;
        card.addEventListener('mouseenter', () => {
          tl?.kill();
          tl = gsap.timeline();
          paths.forEach((p) => {
            tl.to(p, { strokeDashoffset: 0, attr: { 'stroke-width': 110 }, duration: 1.4, ease: 'power2.out' }, 0);
          });
        });
        card.addEventListener('mouseleave', () => {
          tl?.kill();
          tl = gsap.timeline();
          paths.forEach((p, i) => {
            tl.to(p, { strokeDashoffset: lengths[i], attr: { 'stroke-width': 40 }, duration: 0.9, ease: 'power2.out' }, 0);
          });
        });
      });
    }
  </script>
</body>
</html>
