---
/**
 * HeroLoader — schlichtes Intro: Navy-Hintergrund mit „FaktenSchmied"-Schriftzug,
 * sanftes Einblenden, kurz halten, ausblenden. Einmal pro Session.
 * Bei reduzierter Bewegung / ohne JS wird nichts angezeigt.
 */
---
<script is:inline>
  (function () {
    try {
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && !sessionStorage.getItem('fs-intro')) {
        sessionStorage.setItem('fs-intro', '1');
        document.documentElement.classList.add('intro-on', 'intro-lock');
        // Failsafe: Scrollsperre nie länger als nötig
        setTimeout(function () { document.documentElement.classList.remove('intro-lock'); }, 4000);
      }
    } catch (e) {}
  })();
</script>

<div class="intro" id="intro" aria-hidden="true">
  <span class="intro-word">Fakten<span class="o">Schmied</span></span>
</div>

<script>
  const intro = document.getElementById('intro');
  if (intro && document.documentElement.classList.contains('intro-on')) {
    const close = () => {
      intro.classList.add('hide');
      document.documentElement.classList.remove('intro-lock');
      setTimeout(() => intro.remove(), 700);
    };
    setTimeout(close, 1500);
  }
</script>
