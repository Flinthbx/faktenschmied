---
// Dezente Glut-/Funken-Animation (Canvas2D, abhängigkeitsfrei) für dunkle Hero-Bereiche.
---
<canvas class="fx-ember" aria-hidden="true"></canvas>
<style is:global>
  .fx-ember{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0}
</style>
<script is:global>
  (function () {
    function init(){ document.querySelectorAll('canvas.fx-ember').forEach(setup); }
    function setup(c){
      if (c.dataset.on) return; c.dataset.on = '1';
      if (window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var ctx = c.getContext('2d'), W = 0, H = 0, parts = [], dpr = Math.min(window.devicePixelRatio || 1, 2);
      function resize(){ var r = c.getBoundingClientRect(); W = c.width = Math.max(1, r.width * dpr); H = c.height = Math.max(1, r.height * dpr); }
      function mk(seed){ return { x: Math.random()*W, y: seed ? Math.random()*H : H + Math.random()*40*dpr, r: (Math.random()*1.6+0.8)*dpr, s: (Math.random()*0.5+0.18)*dpr, a: Math.random()*0.5+0.2, d: (Math.random()*0.4-0.2)*dpr }; }
      function loop(){
        ctx.clearRect(0,0,W,H); ctx.globalCompositeOperation = 'lighter';
        for (var i=0;i<parts.length;i++){ var p=parts[i]; p.y-=p.s; p.x+=p.d; p.a-=0.0016;
          if (p.y < -20 || p.a <= 0){ parts[i]=mk(false); continue; }
          var R=p.r*6, g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,R);
          g.addColorStop(0,'rgba(255,176,72,'+p.a+')'); g.addColorStop(0.4,'rgba(239,120,0,'+(p.a*0.5)+')'); g.addColorStop(1,'rgba(239,120,0,0)');
          ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,R,0,6.2832); ctx.fill();
        }
        requestAnimationFrame(loop);
      }
      resize();
      var n = Math.min(70, Math.floor(W / (20*dpr)));
      for (var i=0;i<n;i++) parts.push(mk(true));
      loop();
      var rt; window.addEventListener('resize', function(){ clearTimeout(rt); rt=setTimeout(resize,150); });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init); else init();
  })();
</script>
