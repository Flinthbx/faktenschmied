---
// Schrift-Umschalter NUR für die Vorschau-Seiten (/varianten).
// Alle Paarungen stehen unter der SIL Open Font License (frei, auch kommerziell).
const pairs = [
  { id: '0', name: 'Aktuell',    sub: 'Inter · Source Serif 4',   sans: "'Inter',system-ui,sans-serif",            serif: "'Source Serif 4',Georgia,serif" },
  { id: '1', name: 'Editorial',  sub: 'Manrope · Fraunces',       sans: "'Manrope',system-ui,sans-serif",          serif: "'Fraunces',Georgia,serif" },
  { id: '2', name: 'Technisch',  sub: 'Space Grotesk · Spectral', sans: "'Space Grotesk',system-ui,sans-serif",    serif: "'Spectral',Georgia,serif" },
  { id: '3', name: 'Freundlich', sub: 'Plus Jakarta · Lora',      sans: "'Plus Jakarta Sans',system-ui,sans-serif",serif: "'Lora',Georgia,serif" },
  { id: '4', name: 'Magazin',    sub: 'Figtree · Newsreader',     sans: "'Figtree',system-ui,sans-serif",          serif: "'Newsreader',Georgia,serif" },
];
---
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Fraunces:ital,opsz,wght@1,9..144,400;1,9..144,500&family=Space+Grotesk:wght@400;500;600;700&family=Spectral:ital,wght@1,400;1,500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Lora:ital,wght@1,400;1,500&family=Figtree:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@1,6..72,400;1,6..72,500&display=swap" />

<div class="fswitch" data-pairs={JSON.stringify(pairs)}>
  <button class="fs-toggle" aria-expanded="false"><span class="aa">Aa</span> Schrift <span class="cur">Aktuell</span> <span class="cv">▾</span></button>
  <div class="fs-menu" hidden>
    <div class="fs-hd">Schriftart wählen</div>
    {pairs.map((p) => (
      <button class={`fs-opt${p.id === '0' ? ' on' : ''}`} data-id={p.id} data-sans={p.sans} data-serif={p.serif}>
        <b>{p.name}</b><small>{p.sub}</small>
      </button>
    ))}
    <div class="fs-ft">Alle frei lizenziert (OFL)</div>
  </div>
</div>

<style is:global>
  .fswitch{position:fixed;top:92px;right:20px;z-index:121;font-family:var(--sans)}
  .fs-toggle{display:inline-flex;align-items:center;gap:9px;cursor:pointer;border:1px solid rgba(255,255,255,.18);
    background:rgba(12,14,36,.86);backdrop-filter:saturate(1.4) blur(14px);color:#fff;border-radius:100px;
    padding:9px 15px;font-size:13px;font-weight:600;box-shadow:0 14px 40px -14px rgba(0,0,0,.6)}
  .fs-toggle .aa{font-family:var(--serif);font-style:italic;font-size:16px;line-height:1;color:var(--brand)}
  .fs-toggle .cur{color:#C7CAE6;font-weight:500}
  .fs-toggle .cv{transition:transform .25s}
  .fs-toggle[aria-expanded="true"] .cv{transform:rotate(180deg)}
  .fs-menu{position:absolute;top:calc(100% + 8px);right:0;width:236px;background:#fff;border:1px solid var(--line);
    border-radius:14px;padding:8px;box-shadow:0 24px 60px -18px rgba(20,24,59,.4);display:flex;flex-direction:column;gap:2px}
  .fs-menu[hidden]{display:none}
  .fs-hd{font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--slate);padding:8px 10px 4px}
  .fs-opt{display:flex;flex-direction:column;align-items:flex-start;gap:2px;text-align:left;cursor:pointer;
    background:none;border:0;border-radius:9px;padding:10px 12px;transition:background .15s}
  .fs-opt:hover{background:var(--cloud)}
  .fs-opt b{font-size:14px;color:var(--ink);font-weight:700}
  .fs-opt small{font-size:11.5px;color:var(--slate)}
  .fs-opt.on{background:var(--brand-tint)}
  .fs-opt.on b{color:var(--brand-strong)}
  .fs-ft{font-size:11px;color:var(--slate);padding:6px 10px 4px;border-top:1px solid var(--line);margin-top:4px}
  @media(max-width:620px){.fswitch{top:auto;bottom:84px;right:14px}.fs-menu{width:210px}}
</style>

<script is:global>
  (function () {
    function initFontSwitcher() {
      const box = document.querySelector('.fswitch');
      if (!box || box.dataset.bound) return;
      box.dataset.bound = '1';
      const toggle = box.querySelector('.fs-toggle');
      const menu = box.querySelector('.fs-menu');
      const opts = Array.from(box.querySelectorAll('.fs-opt'));
      const root = document.documentElement;

      function apply(sans, serif) {
        root.style.setProperty('--sans', sans);
        root.style.setProperty('--mono', sans);
        root.style.setProperty('--serif', serif);
      }
      function select(opt, save) {
        opts.forEach((o) => o.classList.toggle('on', o === opt));
        apply(opt.dataset.sans, opt.dataset.serif);
        const cur = toggle.querySelector('.cur');
        if (cur) cur.textContent = opt.querySelector('b').textContent;
        if (save) { try { localStorage.setItem('fs-font', opt.dataset.id); } catch (e) {} }
      }

      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        const open = menu.hasAttribute('hidden');
        if (open) { menu.removeAttribute('hidden'); toggle.setAttribute('aria-expanded', 'true'); }
        else { menu.setAttribute('hidden', ''); toggle.setAttribute('aria-expanded', 'false'); }
      });
      opts.forEach((opt) => opt.addEventListener('click', function () {
        select(opt, true);
        menu.setAttribute('hidden', ''); toggle.setAttribute('aria-expanded', 'false');
      }));
      document.addEventListener('click', function (e) {
        if (!box.contains(e.target)) { menu.setAttribute('hidden', ''); toggle.setAttribute('aria-expanded', 'false'); }
      });

      // gespeicherte Auswahl wiederherstellen
      let saved = '0';
      try { saved = localStorage.getItem('fs-font') || '0'; } catch (e) {}
      const init = opts.find((o) => o.dataset.id === saved) || opts[0];
      if (init) select(init, false);
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initFontSwitcher);
    else initFontSwitcher();
  })();
</script>
